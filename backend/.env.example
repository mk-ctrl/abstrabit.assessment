# Backend Environment Variables Example
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Supabase (Database) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Callback URL — must match exactly what is set in your GitHub OAuth App settings.
# Local:      http://localhost:3000/api/auth/github/callback
# Production: https://your-render-service.onrender.com/api/auth/github/callback
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# ── Webhook Security ─────────────────────────────────────────────────────────
# A random secret used to sign and verify incoming GitHub webhook payloads.
# Generate with: openssl rand -hex 20
# IMPORTANT: This value must exactly match the secret stored in the GitHub webhook.
# On Render, set this in the Environment tab — do NOT rely on .env in production.
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here

# Public URL of this backend — used when registering webhooks on GitHub repos.
# Local: use a tunnel like Cloudflare Tunnel or ngrok (e.g. https://abc.trycloudflare.com)
# Production: your Render service URL
BACKEND_PUBLIC_URL=https://your-backend-public-url.onrender.com

# ── Redis (BullMQ Job Queue) ─────────────────────────────────────────────────
# Local:      redis://127.0.0.1:6379
# Production: your Redis Cloud connection string
REDIS_URL=redis://127.0.0.1:6379

# ── OpenRouter AI ────────────────────────────────────────────────────────────
# Free-tier key from https://openrouter.ai — used to classify issues/PRs
OPENROUTER_API_KEY=your_openrouter_api_key

# ── JWT Session ──────────────────────────────────────────────────────────────
# Secret used to sign user session tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_session_secret_here

# ── Frontend CORS ────────────────────────────────────────────────────────────
# The deployed frontend URL. Used for OAuth redirects and CORS allowlist.
# Local:      http://localhost:5173
# Production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
